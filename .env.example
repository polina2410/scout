# ── Backend ──────────────────────────────────────────────────────────────────
PORT=8080
API_KEY=your-api-key-here
DB_PATH=../dataset/predictions.db

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=scout
MINIO_USE_SSL=false
THUMB_CACHE_SIZE_MB=500
# Per-IP rate limit for the unauthenticated /thumbnails endpoint.
# Burst covers a full gallery grid loading at once; rate throttles sustained floods.
THUMB_RATE_PER_SEC=30
THUMB_RATE_BURST=60
# Set to true ONLY when running behind a trusted reverse proxy / load balancer.
# When true, the rate limiter keys on X-Forwarded-For / X-Real-IP. Leave false
# for direct exposure — otherwise clients could spoof their IP to evade limits.
TRUST_PROXY_HEADERS=false

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
VITE_API_KEY=your-api-key-here

# ── Seed ──────────────────────────────────────────────────────────────────────
API_URL=http://localhost:8080
IMAGES_DIR=../dataset/images